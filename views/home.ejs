<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <title>Dashboard | URL Shortener</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Manrope:wght@700;800&display=swap" rel="stylesheet">
    <style>
      :root {
        --background: #f8fafb;
        --surface: #ffffff;
        --primary: #0d9488; /* Teal */
        --accent: #fb923c;  /* Peach */
        --text-main: #1e293b;
        --text-sub: #64748b;
        --border: #e2e8f0;
        --shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
    
      body {
        font-family: 'Inter', sans-serif;
        background-color: var(--background);
        color: var(--text-main);
        min-height: 100vh;
        padding: 40px 20px;
      }
    
      .container {
        max-width: 900px;
        margin: 0 auto;
      }

      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
      }

      h1 {
        font-family: 'Manrope', sans-serif;
        font-size: 24px;
        font-weight: 800;
        color: var(--primary);
        letter-spacing: -0.02em;
      }

      .btn-logout {
        color: var(--text-sub);
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        padding: 8px 16px;
        border-radius: 8px;
        border: 1px solid var(--border);
        transition: all 0.2s;
      }

      .btn-logout:hover {
        background: #fee2e2;
        color: #ef4444;
        border-color: #fecaca;
      }

      /* ---- Generated URL styling ---- */
      .success-box {
        background: #f0fdfa;
        padding: 16px 20px;
        border-radius: 12px;
        border: 1px solid #ccfbf1;
        color: #134e4a;
        font-size: 15px;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        box-shadow: var(--shadow);
      }

      .success-box strong {
        color: var(--primary);
        word-break: break-all;
      }

      .btn-copy {
        background: white;
        border: 1.5px solid var(--border);
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        color: var(--text-sub);
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 4px;
      }

      .btn-copy:hover {
        border-color: var(--primary);
        color: var(--primary);
        background: #f0fdfa;
      }

      .btn-copy.copied {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
      }
    
      /* ---- Form container ---- */
      .form-card {
        background: var(--surface);
        padding: 32px;
        border-radius: 16px;
        box-shadow: var(--shadow);
        border: 1px solid var(--border);
        margin-bottom: 40px;
      }

      .form-card label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        color: var(--text-sub);
        margin-bottom: 10px;
      }
    
      .input-group {
        display: flex;
        gap: 12px;
      }

      input[type="text"] {
        flex: 1;
        padding: 12px 16px;
        border-radius: 10px;
        border: 1.5px solid var(--border);
        font-size: 15px;
        outline: none;
        transition: all 0.2s;
      }
    
      input[type="text"]:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.1);
      }
    
      button[type="submit"] {
        padding: 12px 24px;
        background: var(--primary);
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
      }
    
      button[type="submit"]:hover {
        background: #0f766e;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(13, 148, 136, 0.2);
      }
    
      /* --- Table Styling --- */
      .table-wrapper {
        background: var(--surface);
        border-radius: 16px;
        box-shadow: var(--shadow);
        border: 1px solid var(--border);
        overflow: hidden;
      }

      .fl-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
        text-align: left;
      }

      .fl-table thead th {
        background: #f1f5f9;
        color: var(--text-sub);
        padding: 16px;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 11px;
        letter-spacing: 0.05em;
      }
    
      .fl-table td {
        padding: 16px;
        border-top: 1px solid var(--border);
        color: var(--text-main);
      }
    
      .fl-table tbody tr:hover {
        background: #f8fafb;
      }

      .short-id {
        font-family: monospace;
        background: #f1f5f9;
        padding: 4px 8px;
        border-radius: 6px;
        color: var(--primary);
        font-weight: 600;
      }

      .clicks-badge {
        background: #ffedd5;
        color: #9a3412;
        padding: 4px 10px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 700;
      }

      .redirect-link {
        color: var(--primary);
        text-decoration: none;
        font-weight: 500;
      }

      .redirect-link:hover {
        text-decoration: underline;
      }

      @media (min-width: 768px) {
        .domain-only { display: none; }
      }

      @media (max-width: 767px) {
        .full-url { display: none; }
        .domain-only { display: inline; }
      }
    
      @media (max-width: 640px) {
        .input-group {
          flex-direction: column;
        }
        
        .fl-table thead {
          display: none;
        }

        .fl-table tr {
          display: block;
          padding: 20px;
          border-bottom: 1px solid var(--border);
        }

        .fl-table td {
          display: flex;
          justify-content: space-between;
          padding: 8px 0;
          border: none;
        }

        .fl-table td::before {
          content: attr(data-label);
          font-weight: 600;
          color: var(--text-sub);
          font-size: 12px;
        }
      }
    </style>
</head>

<body>
  <div class="container">
    <header>
      <h1>URL SHORTENER</h1>
      <a href="/user/logout" class="btn-logout">Logout</a>
    </header>

    <% if (locals.id) { %>
      <div class="success-box">
        <span>URL GENERATED: <strong id="generated-url">https://url-shortner-41ml.onrender.com/url/<%= id %></strong></span>
        <button class="btn-copy" onclick="copyToClipboard('generated-url', this)">
          Copy
        </button>
      </div>
    <% } %>

    <div class="form-card">
      <form action="/url" method="POST">
        <label for="url">Enter your original URL</label>
        <div class="input-group">
          <input type="text" id="url" placeholder="https://example.com" name="url" required>
          <button type="submit">Generate Link</button>
        </div>
      </form>
    </div>

    <% if (locals.urls) { %>
      <div class="table-wrapper">
        <table class="fl-table">
          <thead>
            <tr>
              <th>S NO</th>
              <th>SHORT ID</th>
              <th>REDIRECT URL</th>
              <th>CLICKS</th>
            </tr>
          </thead>
          <tbody>
            <% urls.forEach((url, index) => { %>
              <tr>
                <td data-label="S NO"><%= index + 1 %></td>
                <td data-label="SHORT ID">
                  <div style="display: flex; align-items: center; gap: 8px; justify-content: center;">
                    <span class="short-id"><%= url.shortId %></span>
                    <button class="btn-copy" 
                            data-url="https://url-shortner-41ml.onrender.com/url/<%= url.shortId %>"
                            onclick="copyFromAttribute(this)">
                      Copy
                    </button>
                  </div>
                </td>
                <td data-label="REDIRECT URL">
                  <a href="<%= url.redirectUrl %>" target="_blank" class="redirect-link">
                    <span class="full-url"><%= url.redirectUrl %></span>
                    <% 
                      let domain = url.redirectUrl;
                      try { 
                        domain = new URL(url.redirectUrl).hostname;
                      } catch(e) {} 
                    %>
                    <span class="domain-only"><%= domain %></span>
                  </a>
                </td>
                <td data-label="CLICKS"><span class="clicks-badge"><%= url.visitHistory.length %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <script>
    function copyFromAttribute(btn) {
      const urlText = btn.getAttribute('data-url');
      navigator.clipboard.writeText(urlText).then(() => {
        const originalText = btn.innerText;
        btn.innerText = 'Copied!';
        btn.classList.add('copied');
        
        setTimeout(() => {
          btn.innerText = originalText;
          btn.classList.remove('copied');
        }, 2000);
      });
    }

    function copyToClipboard(elementId, btn) {
      const urlText = document.getElementById(elementId).innerText;
      navigator.clipboard.writeText(urlText).then(() => {
        const originalText = btn.innerText;
        btn.innerText = 'Copied!';
        btn.classList.add('copied');
        
        setTimeout(() => {
          btn.innerText = originalText;
          btn.classList.remove('copied');
        }, 2000);
      });
    }

    window.addEventListener("pageshow", function (event) {
      if (event.persisted || window.performance.navigation.type === 2) {
        window.location.reload();
      }
    });
  </script>
</body>

</html>
